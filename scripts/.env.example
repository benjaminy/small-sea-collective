# Dropbox app credentials for the Small Sea Collective Dropbox app.
# Copy this file to scripts/.env and fill in the real values.
# Get these from https://www.dropbox.com/developers/apps → your app → Settings.
#
# Usage:
#   source scripts/.env
#   uv run python scripts/setup_dropbox_auth.py
#   uv run python scripts/setup_dropbox_workspace.py

export SMALL_SEA_DROPBOX_APP_KEY=your_app_key_here
export SMALL_SEA_DROPBOX_APP_SECRET=your_app_secret_here
